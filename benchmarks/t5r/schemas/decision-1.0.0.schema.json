{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verdictlayer.dev/schemas/verdict-bench/decision-1.0.0.schema.json",
  "title": "Verdict Bench gated decision",
  "type": "object",
  "required": [
    "schema_version", "run_id", "arm", "domain", "task_id", "trial",
    "decision_idx", "context_key", "incumbent_component",
    "selected_component", "outcome", "candidate_scores", "bernoulli_outcomes"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "run_id": {"type": "string"},
    "arm": {"type": "string"},
    "domain": {"type": "string"},
    "task_id": {"type": "string"},
    "trial": {"type": "integer", "minimum": 0},
    "decision_idx": {"type": "integer", "minimum": 0},
    "context_key": {"type": "string"},
    "incumbent_component": {"type": "string"},
    "challenger_component": {"type": ["string", "null"]},
    "selected_component": {"type": "string"},
    "outcome": {"type": "string"},
    "candidate_scores": {
      "type": "object",
      "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}
    },
    "bernoulli_outcomes": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 0, "maximum": 1}
    },
    "accept_log_e": {"type": ["number", "null"]},
    "refute_log_e": {"type": ["number", "null"]},
    "threshold": {"type": ["number", "null"]}
  },
  "additionalProperties": true
}
