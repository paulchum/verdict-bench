{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verdictlayer.dev/schemas/verdict-bench/price-sheet-1.0.0.schema.json",
  "title": "Verdict Bench provider price sheet",
  "type": "object",
  "required": ["schema_version", "as_of", "currency", "unit", "models"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "as_of": {"type": "string", "format": "date"},
    "currency": {"const": "USD"},
    "unit": {"const": "per_million_tokens"},
    "models": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "input_per_mtok",
          "cached_input_per_mtok",
          "output_per_mtok",
          "source"
        ],
        "properties": {
          "input_per_mtok": {"type": "number", "minimum": 0},
          "cached_input_per_mtok": {"type": "number", "minimum": 0},
          "output_per_mtok": {"type": "number", "minimum": 0},
          "source": {"type": "string", "format": "uri"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
