{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verdictlayer.dev/schemas/verdict-bench/event-1.0.0.schema.json",
  "title": "Verdict Bench evidence event",
  "type": "object",
  "required": ["schema_version", "run_id", "arm", "domain", "task_id", "trial", "event", "detail"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "run_id": {"type": "string"},
    "arm": {"type": "string"},
    "domain": {"type": "string"},
    "task_id": {"type": "string"},
    "trial": {"type": "integer", "minimum": 0},
    "decision_idx": {"type": ["integer", "null"], "minimum": 0},
    "component": {"type": ["string", "null"]},
    "context_key": {"type": ["string", "null"]},
    "event": {"type": "string", "minLength": 1},
    "detail": {"type": "string"},
    "log_e": {"type": ["number", "null"]},
    "threshold": {"type": ["number", "null"]}
  },
  "additionalProperties": true
}
