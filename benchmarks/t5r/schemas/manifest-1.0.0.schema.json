{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verdictlayer.dev/schemas/verdict-bench/manifest-1.0.0.schema.json",
  "title": "Verdict Bench run manifest",
  "type": "object",
  "required": ["schema_version", "run_id", "stage", "status"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "run_id": {"type": "string", "minLength": 1},
    "stage": {"type": "string", "minLength": 1},
    "status": {"type": "string", "minLength": 1},
    "arms": {"type": "array", "items": {"type": "string"}},
    "trials": {"type": "array", "items": {"type": "integer", "minimum": 0}},
    "funded_credit_cap_usd": {"type": "number", "exclusiveMinimum": 0},
    "cash_spend_authorized_usd": {"const": 0.0}
  },
  "additionalProperties": true
}
