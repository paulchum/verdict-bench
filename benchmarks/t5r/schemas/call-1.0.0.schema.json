{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verdictlayer.dev/schemas/verdict-bench/call-1.0.0.schema.json",
  "title": "Verdict Bench provider call",
  "type": "object",
  "required": [
    "schema_version", "run_id", "arm", "domain", "task_id", "trial",
    "purpose", "requested_model", "resolved_model", "physical_call_id",
    "status", "attempts", "input_tokens", "cached_input_tokens",
    "output_tokens", "reasoning_tokens", "total_tokens", "billed_usd"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "run_id": {"type": "string", "minLength": 1},
    "arm": {"type": "string", "minLength": 1},
    "domain": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "trial": {"type": "integer", "minimum": 0},
    "decision_idx": {"type": ["integer", "null"], "minimum": 0},
    "component": {"type": ["string", "null"]},
    "context_key": {"type": ["string", "null"]},
    "purpose": {"type": "string", "minLength": 1},
    "requested_model": {"type": "string", "minLength": 1},
    "resolved_model": {"type": ["string", "null"]},
    "physical_call_id": {"type": "string", "minLength": 8},
    "request_id": {"type": ["string", "null"]},
    "status": {"enum": ["success", "error", "simulated"]},
    "attempts": {"type": "integer", "minimum": 1},
    "input_tokens": {"type": "integer", "minimum": 0},
    "cached_input_tokens": {"type": "integer", "minimum": 0},
    "output_tokens": {"type": "integer", "minimum": 0},
    "reasoning_tokens": {"type": "integer", "minimum": 0},
    "total_tokens": {"type": "integer", "minimum": 0},
    "billed_usd": {"type": "number", "minimum": 0},
    "provider_cost_usd": {"type": ["number", "null"], "minimum": 0},
    "latency_seconds": {"type": ["number", "null"], "minimum": 0},
    "score": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "error": {"type": ["string", "null"]}
  },
  "additionalProperties": true
}
